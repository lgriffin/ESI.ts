{
  "name": "@lgriffin/esi.ts",
  "version": "5.3.0",
  "description": "This is a TypeScript Implementation for the EVE Online API offered through ESI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "ts-node examples/character-profile.ts",
    "example": "ts-node examples/character-profile.ts",
    "example:status": "ts-node examples/status.ts",
    "example:character": "ts-node examples/character-lookup.ts",
    "example:universe": "ts-node examples/universe-info.ts",
    "example:market": "ts-node examples/market-prices.ts",
    "example:alliance": "ts-node examples/alliance-info.ts",
    "example:route": "ts-node examples/route-planner.ts",
    "example:wars": "ts-node examples/wars.ts",
    "example:sovereignty": "ts-node examples/sovereignty.ts",
    "example:skyhooks": "ts-node examples/skyhooks.ts",
    "example:mercenary": "ts-node examples/mercenary.ts",
    "example:access-lists": "ts-node examples/access-lists.ts",
    "example:industry": "ts-node examples/industry.ts",
    "example:incursions": "ts-node examples/incursions.ts",
    "example:dogma": "ts-node examples/dogma.ts",
    "example:wallet": "ts-node examples/wallet-overview.ts",
    "example:skills": "ts-node examples/skills-overview.ts",
    "example:assets": "ts-node examples/assets-inventory.ts",
    "example:contracts": "ts-node examples/contracts-browser.ts",
    "example:killmails": "ts-node examples/killmails.ts",
    "example:fleet": "ts-node examples/fleet-operations.ts",
    "example:mail": "ts-node examples/mail-inbox.ts",
    "example:location": "ts-node examples/location-tracker.ts",
    "example:fittings": "ts-node examples/fittings-clones.ts",
    "example:contacts": "ts-node examples/contacts.ts",
    "example:rate-limiting": "ts-node examples/rate-limiting.ts",
    "example:cursor-pagination": "ts-node examples/cursor-pagination.ts",
    "example:token-refresh": "ts-node examples/token-refresh.ts",
    "example:retry-timeout-metadata": "ts-node examples/retry-timeout-metadata.ts",
    "example:streaming": "ts-node examples/streaming-pagination.ts",
    "token:create": "ts-node scripts/create-token.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --config jest.unit.config.cjs",
    "test:watch": "jest --config jest.unit.config.cjs --watch",
    "bdd": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions",
    "bdd:alliance": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/alliance",
    "bdd:assets": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/assets",
    "bdd:calendar": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/calendar",
    "bdd:character": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/character",
    "bdd:clones": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/clones",
    "bdd:contacts": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/contacts",
    "bdd:contracts": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/contracts",
    "bdd:corporation": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/corporation",
    "bdd:dogma": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/dogma",
    "bdd:etag-caching": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/etag-caching",
    "bdd:factions": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/factions",
    "bdd:fittings": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/fittings",
    "bdd:fleets": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/fleets",
    "bdd:freelance": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/freelance",
    "bdd:incursions": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/incursions",
    "bdd:industry": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/industry",
    "bdd:insurance": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/insurance",
    "bdd:killmails": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/killmails",
    "bdd:location": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/location",
    "bdd:loyalty": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/loyalty",
    "bdd:mail": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/mail",
    "bdd:market": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/market",
    "bdd:meta": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/meta",
    "bdd:pi": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/pi",
    "bdd:route": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/route",
    "bdd:search": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/search",
    "bdd:skills": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/skills",
    "bdd:skyhooks": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/skyhooks",
    "bdd:sovereignty": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/sovereignty",
    "bdd:mercenary": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/mercenary",
    "bdd:access-lists": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/access-lists",
    "bdd:status": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/status",
    "bdd:ui": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/ui",
    "bdd:universe": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/universe",
    "bdd:wallet": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/wallet",
    "bdd:wars": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/core/wars",
    "bdd:integration": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/integration",
    "bdd:performance": "jest --config jest.unit.config.cjs --testPathPattern=step-definitions/performance",
    "coverage": "jest --config jest.unit.config.cjs --coverage",
    "test:integration": "jest --config jest.integration.config.cjs",
    "test:integration:live": "node -e \"process.env.ESI_LIVE_TESTS='true';require('child_process').execSync('npx jest --config jest.integration.config.cjs --testPathPattern=live-esi',{stdio:'inherit',env:Object.assign({},process.env,{ESI_LIVE_TESTS:'true'})})\"",
    "test:integration:gated": "node --env-file=.env -e \"require('child_process').execSync('npx jest --config jest.integration.config.cjs --testPathPattern=gated-auth',{stdio:'inherit',env:Object.assign({},process.env,{ESI_GATED_TESTS:'true'})})\"",
    "test:all": "npm run test && npm run bdd && npm run test:integration",
    "generate:types": "ts-node scripts/generate-esi-types.ts",
    "knip": "knip",
    "validate:esi": "ts-node scripts/validate-esi-endpoints.ts",
    "validate": "npm run lint && npm run format:check && npm run build && npm run coverage && knip --no-exit-code",
    "validate:versions": "ts-node scripts/validate-versions.ts",
    "check:all": "npm run lint && npm run format:check && npm run build && npm run coverage && knip --no-exit-code && npm run validate:esi && npm run validate:versions",
    "docs": "typedoc --options typedoc.json",
    "docs:watch": "typedoc --options typedoc.json --watch",
    "docs:serve": "npx http-server docs -p 8080 -o",
    "clean": "rm -rf dist coverage docs",
    "clean:docs": "rm -rf docs",
    "prepare": "husky && npm run build",
    "health-check": "ts-node -e \"import('./src/EsiClient').then(({EsiClient}) => new EsiClient().healthCheck().then(console.log))\""
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "eve-online",
    "esi",
    "api-client",
    "typescript",
    "eve",
    "caching",
    "rate-limiting",
    "mmo"
  ],
  "author": "lgriffin",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/lgriffin/ESI.ts#readme",
  "bugs": {
    "url": "https://github.com/lgriffin/ESI.ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lgriffin/ESI.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-cucumber": "^4.5.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-junit": "^17.0.0",
    "knip": "^6.6.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "winston": "^3.13.0"
  }
}
