# ESI.ts Environment Configuration
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be committed.
#
# To obtain an EVE SSO access token:
#   1. Register an application at https://developers.eveonline.com/
#   2. Set callback URL and select the ESI scopes you need
#   3. Complete the OAuth2 flow to receive an access token
#   4. Paste the token below
#
# See: https://docs.esi.evetech.net/docs/sso/

# EVE SSO access token (required for authenticated endpoints)
# ESI_ACCESS_TOKEN=your-eve-sso-access-token

# User-Agent identifier sent with every request (optional, default: 'esi-client')
# ESI_CLIENT_ID=my-app-name

# ESI base URL (optional, default: https://esi.evetech.net)
# ESI_BASE_URL=https://esi.evetech.net

# Log level: error, warn, info, debug (optional, default: warn)
# ESI_LOG_LEVEL=warn
